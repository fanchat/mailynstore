{
	http_port 80
	https_port 8443
	auto_https disable_redirects
}

mailyn.cn:80 {
	@umami {
		path /script.js
		path /api/send
		path /api/collect
	}
	@ws-call {
		path /ws-call*
	}
	@admin {
		path /admin*
		path /chatadmin*
	}
	reverse_proxy @umami localhost:3000
	reverse_proxy @admin localhost:7777
	reverse_proxy @ws-call localhost:3001
	# 产品图片、头像、社交媒体文件——Caddy 直接从文件系统读
	handle_path /uploads/* {
		root * /home/ding/mailyns/medusa/apps/backend/uploads
		file_server browse
	}
	reverse_proxy localhost:8000
}

mailyn.cn:8443 {
	@umami {
		path /script.js
		path /api/send
		path /api/collect
	}
	@ws-call {
		path /ws-call*
	}
	@admin {
		path /admin*
		path /chatadmin*
	}
	reverse_proxy @umami localhost:3000
	reverse_proxy @admin localhost:7777
	reverse_proxy @ws-call localhost:3001
	# 产品图片、头像、社交媒体文件——Caddy 直接从文件系统读
	handle_path /uploads/* {
		root * /home/ding/mailyns/medusa/apps/backend/uploads
		file_server browse
	}
	reverse_proxy localhost:8000
}

# 信令服务器——独立站点，不走子路径
ws.mailyn.cn:8443 {
	reverse_proxy localhost:3001
}
